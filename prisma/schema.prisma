generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANTS
// ─────────────────────────────────────────────

model Tenant {
  id                       String    @id @default(cuid())
  name                     String
  tenantType               String    // "operator" | "lypx_direct"
  marketplaceParticipation Boolean   @default(false)
  createdAt                DateTime  @default(now())

  // Onboarding & lifecycle
  contactName              String?
  contactEmail             String?
  contactPhone             String?
  status                   String    @default("active") // invited | active | suspended
  workosOrganisationId     String?
  workosInvitationId       String?
  invitedAt                DateTime?
  activatedAt              DateTime?

  driverMemberships        OperatorDriverMembership[]
  registeredVehicles       Vehicle[]
  orders                   Order[]
  preference               TenantPreference?
  users                    TenantUser[]
}

// ─────────────────────────────────────────────
// DRIVERS & VEHICLES (global registry)
// ─────────────────────────────────────────────

model Driver {
  id               String   @id @default(cuid())
  identityHash      String   @unique // hash of normalized license_number + national_id
  firstName         String
  lastName          String
  phoneNumber       String
  licenseNumber     String?
  licenseIssuedDate DateTime?
  complianceStatus  String   @default("pending") // pending | active | expiring_soon | suspended
  tier2Qualified    Boolean  @default(false)
  sourceType        String   @default("operator_added") // "operator_added" | "self_submitted"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents         ComplianceDocument[]
  memberships       OperatorDriverMembership[]
  vehicleOwnerships VehicleOwnership[]
  orders            Order[]
  submission        DriverSubmission?
}

model OperatorDriverMembership {
  id               String   @id @default(cuid())
  tenantId         String
  driverId         String
  tier1Member      Boolean  @default(false)
  relationshipType String   // "employed" | "contracted"
  addedAt          DateTime @default(now())

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  driver           Driver   @relation(fields: [driverId], references: [id])

  @@unique([tenantId, driverId])
}

model Vehicle {
  id                   String   @id @default(cuid())
  registeredByTenantId String
  make                 String
  model                String
  plateNumber          String   @unique
  status               String   @default("inactive") // active | inactive | suspended — DERIVED
  insuranceCompany     String?
  vehicleClass         String?  // "VVV" | "AVF" | "NVE"
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  registeredByTenant Tenant   @relation(fields: [registeredByTenantId], references: [id])
  documents          ComplianceDocument[]
  ownership          VehicleOwnership[]
  orders             Order[]
}

model VehicleOwnership {
  id               String    @id @default(cuid())
  vehicleId        String
  driverId         String
  relationshipType String    // "owned" | "contracted"
  contractStatus   String?   // "active" | "expired" | "terminated" — null if owned
  contractExpiry   DateTime?
  createdAt        DateTime  @default(now())

  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id])
  driver           Driver    @relation(fields: [driverId], references: [id])
}

// Polymorphic: attaches to Driver OR Vehicle (exactly one should be set)
model ComplianceDocument {
  id                 String    @id @default(cuid())
  entityType         String    // "driver" | "vehicle"
  driverId           String?
  vehicleId          String?
  docType            String    // license | nric | insurance | registration | inspection | background_check | rental_agreement
  expiryDate         DateTime
  issuedDate         DateTime?
  status             String    @default("pending_review") // verified | pending_review | expired | rejected
  verificationMethod String    @default("manual")
  uploadedAt         DateTime  @default(now())
  reviewedBy         String?
  reviewedAt         DateTime?

  driver  Driver?  @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  file    DocumentFile?

  @@index([expiryDate])
  @@index([driverId])
  @@index([vehicleId])
}

// Stores uploaded file reference — file bytes live in Cloudflare R2
model DocumentFile {
  id                   String   @id @default(cuid())
  complianceDocumentId String   @unique
  fileName             String
  mimeType             String
  size                 Int
  storageKey           String   // R2 object key: documents/<driverId>/<docType>/<uuid>.<ext>
  uploadedAt           DateTime @default(now())

  document ComplianceDocument @relation(fields: [complianceDocumentId], references: [id])
}

// ─────────────────────────────────────────────
// ACCOUNTS & CLAIMS
// ─────────────────────────────────────────────

model Account {
  id              String   @id @default(cuid())
  name            String
  uen             String?  @unique  // Singapore UEN — primary dedup key
  customerSegment String   // hotel | mice | tdm | dmc | corporate_general
  sourceType      String   // "operator_sourced" | "lypx_sourced"
  createdAt       DateTime @default(now())

  claims           AccountClaim[]
  takeoverRequests TakeoverRequest[]
  orders           Order[]
  claimConflicts   ClaimConflict[]
}

model ClaimConflict {
  id                  String    @id @default(cuid())
  accountId           String
  existingClaimId     String
  challengerTenantId  String
  challengerNote      String?
  status              String    @default("pending") // pending | allowed | rejected | flagged
  adminDecision       String?
  decidedBy           String?
  decidedAt           DateTime?
  createdAt           DateTime  @default(now())

  account             Account   @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
}

model AccountClaim {
  id                  String    @id @default(cuid())
  accountId           String
  claimingPartyType   String    // "operator" | "lypx_direct"
  claimingPartyId     String?   // tenantId if operator, null if lypx_direct
  status              String    @default("claimed") // claimed | won | expired | superseded
  claimedAt           DateTime  @default(now())
  expiryAt            DateTime  // claimedAt + 90 days
  wonAt               DateTime?
  firstTripOrderId    String?
  lastTripCompletedAt DateTime?
  protectionTier      String    @default("standard") // standard | long_term

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, status])
}

model TakeoverRequest {
  id                     String    @id @default(cuid())
  accountId              String
  currentOwnerType       String
  currentOwnerId         String?
  requestingPartyType    String
  requestingPartyId      String?
  status                 String    @default("pending") // pending | conditional | approved | denied
  score                  Int?
  scoreBreakdown         Json?
  rightToRespondInvoked  Boolean   @default(false)
  rightToRespondDeadline DateTime?
  requestedAt            DateTime  @default(now())
  reviewedAt             DateTime?
  decisionNotes          String?

  account Account @relation(fields: [accountId], references: [id])
}

// ─────────────────────────────────────────────
// ORDERS (manual log — no automation yet)
// ─────────────────────────────────────────────

model Order {
  id                String    @id @default(cuid())
  accountId         String
  driverId          String?
  vehicleId         String?
  tenantId          String    // fulfilling tenant
  status            String    @default("booked") // booked | assigned | en_route | arrived | started | completed | cancelled
  pickupTime        DateTime
  pickupLocation    String
  dropoffLocation   String
  notes             String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  // Marketplace fee breakdown (lypx_direct orders only)
  tripFare          Float?
  lypxFee           Float?
  operatorReceives  Float?
  rateApplied       String?   // "percentage" | "floor" | null for non-marketplace trips
  takeRateSnapshot  Float?    // take rate % at time of order creation
  floorRateSnapshot Float?    // floor SGD at time of order creation

  account Account  @relation(fields: [accountId], references: [id])
  driver  Driver?  @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  tenant  Tenant   @relation(fields: [tenantId], references: [id])

  @@index([accountId])
  @@index([status])
}

// ─────────────────────────────────────────────
// PLATFORM CONFIGURATION
// ─────────────────────────────────────────────

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String
  updatedBy   String?  // admin WorkOS user ID
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// PHONE VERIFICATION (driver self-onboarding OTP)
// ─────────────────────────────────────────────

model PhoneVerification {
  id         String    @id @default(cuid())
  phone      String
  code       String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

// ─────────────────────────────────────────────
// TENANT PREFERENCES (operator settings)
// ─────────────────────────────────────────────

model TenantPreference {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  accentColour String   @default("#E5A93C")
  timezone     String   @default("Asia/Singapore")
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
}

// Maps WorkOS user IDs to operator tenants
model TenantUser {
  id       String @id @default(cuid())
  userId   String // WorkOS user ID
  tenantId String
  role     String @default("dispatcher") // "admin" | "dispatcher"

  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// USER PREFERENCES
// ─────────────────────────────────────────────

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique // WorkOS user ID
  timezone  String   @default("Asia/Singapore")
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// DRIVER SELF-ONBOARDING SUBMISSION
// ─────────────────────────────────────────────

model DriverSubmission {
  id                          String    @id @default(cuid())
  driverId                    String    @unique
  submittedAt                 DateTime  @default(now())

  // Personal details
  firstName                   String
  lastName                    String
  nricNumber                  String
  phoneNumber                 String    // OTP-verified at submission

  // Driving credentials
  drivingLicenceNumber        String
  drivingLicenceIssuedDate    DateTime

  // Vocational licence
  vocationalLicenceNumber     String
  vocationalLicenceExpiryDate DateTime  // cross-checked against upload

  // Vehicle (optional)
  vehicleMake                 String?
  vehicleModel                String?
  vehiclePlate                String?
  vehicleRelationship         String?   // "owned" | "rented"

  // Admin review
  adminNotes                  String?
  flagReason                  String?
  rejectionReason             String?
  reviewedBy                  String?
  reviewedAt                  DateTime?

  driver Driver @relation(fields: [driverId], references: [id])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // "compliance" | "account_claim" | "order" | "takeover_request"
  entityId   String
  action     String   // e.g. "suspended", "claimed", "won", "status_changed"
  actorId    String?  // admin user id, or "system" for automated transitions
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
